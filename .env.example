# Google OAuth — create credentials at https://console.cloud.google.com/
# Authorized redirect URI must include: http://localhost:3333/auth/google/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Random string used to sign sessions — change this to something long and random
SESSION_SECRET=change-me-to-a-long-random-string

# Google account email that will have admin access
ADMIN_EMAIL=you@gmail.com

# Public URL of the app (used to build the OAuth callback URL)
APP_URL=http://localhost:3333

# Server port
PORT=3333

# Path to the SQLite database file
DB_PATH=./data/retro.db
